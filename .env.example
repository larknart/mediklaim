# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://mediklaim:password@localhost:5432/mediklaim?schema=public"

# ─── Auth ─────────────────────────────────────────────────────────────────────
AUTH_SECRET="generate-with-openssl-rand-base64-32"   # preferred (NextAuth v5)
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32" # fallback — set either one
NEXTAUTH_URL="http://localhost:3000"

# ─── AI / OCR ─────────────────────────────────────────────────────────────────
AI_PROVIDER="ollama"                          # "ollama" | "gemini" | "manual"
OLLAMA_BASE_URL="http://ollama.internal:11434"
OLLAMA_MODEL="qwen2.5vl:7b"                  # vision model — OCR receipt extraction
# OLLAMA_REASONING_MODEL="qwen2.5:7b"        # text model — item eligibility reasoning (optional, defaults to OLLAMA_MODEL)
# GEMINI_API_KEY=""

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST="mail.mds.gov.my"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="mediklaim@mds.gov.my"
SMTP_PASS=""
SMTP_FROM_NAME="MediKlaim MDS"

# ─── WhatsApp (Evolution API) ─────────────────────────────────────────────────
WA_ENABLED="false"
EVOLUTION_BASE_URL="https://evo.yourdomain.my"
EVOLUTION_INSTANCE="mediklaim"
EVOLUTION_API_KEY=""

# ─── App ──────────────────────────────────────────────────────────────────────
DEFAULT_ANNUAL_LIMIT="1200"
CRON_SECRET="generate-random-secret"
TZ="Asia/Kuala_Lumpur"
NODE_ENV="development"
